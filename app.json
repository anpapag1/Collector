{
  "expo": {
    "name": "Collector",
    "slug": "Collector",
    "scheme": "collector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#006A60",
        "foregroundImage": ".assets/android_icons/drawable-xxxhdpi/ic_notification.png`"
      },
      "package": "com.anonymous.Collector"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#006A60"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76925531-f658-4eab-a5ca-5b72830599cb"
      }
    },
    "owner": "anpapag1"
  }
}
