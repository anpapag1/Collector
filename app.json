{
  "expo": {
    "name": "Collector",
    "slug": "Collector",
    "scheme": "collector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#006A60",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.anonymous.Collector"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-font",
      "expo-splash-screen"
    ]
  }
}
