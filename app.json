{
  "expo": {
    "name": "Collector",
    "slug": "Collector",
    "scheme": "collector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2589C8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.anonymous.Collector"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-font",
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#2589C8"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "@sentry/react-native/expo",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Collector uses your location to tag entries with GPS coordinates."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Collector needs photo access to attach images to entries.",
          "cameraPermission": "Collector needs camera access to capture photos for entries."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76925531-f658-4eab-a5ca-5b72830599cb"
      }
    },
    "owner": "anpapag1"
  }
}
