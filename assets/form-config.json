{
  "formId": "template-001",
  "formTitle": "Template",
  "version": "2.0",
  "sections": [
    { "id": "sec-building", "title": "Κτίριο" },
    { "id": "sec-public", "title": "Δημόσιος χώρος" },
    { "id": "sec-parking", "title": "Θέση Στάθμευσης ΑμεΑ" },
    { "id": "sec-other", "title": "Άλλο" }
  ],
  "fields": [
    {
      "id": "location",
      "label": "GPS location",
      "type": "gps",
      "required": true,
      "auto": false
    },
    {
      "id": "surveyDate",
      "label": "Survey date",
      "type": "date",
      "required": true,
      "auto": true
    },
    {
      "id": "followUpDate",
      "label": "Follow-up date",
      "type": "date",
      "required": false,
      "auto": false
    },
    {
      "id": "description",
      "label": "Description",
      "type": "textarea",
      "required": false,
      "placeholder": "Describe the site in detail…"
    },
    {
      "id": "count",
      "label": "Item count",
      "type": "number",
      "required": false,
      "placeholder": "0"
    },
    {
      "id": "category",
      "label": "Category",
      "type": "select",
      "required": true,
      "options": ["Κτίριο", "Δημόσιος χώρος", "Θέση Στάθμευσης ΑμεΑ", "Άλλο"]
    },
    {
      "id": "condition",
      "label": "Condition",
      "type": "select",
      "required": false,
      "options": ["Excellent", "Good", "Fair", "Poor", "Critical"]
    },
    {
      "id": "issues",
      "label": "Issues observed",
      "type": "select",
      "required": false,
      "multiple": true,
      "allowOther": true,
      "options": ["Vandalism", "Flooding", "Overgrowth", "Structural damage", "Lighting fault", "Access blocked"]
    },
    {
      "id": "accessible",
      "label": "Publicly accessible",
      "type": "boolean",
      "required": false
    },
    {
      "id": "rating",
      "label": "Overall rating",
      "type": "rating",
      "required": true,
      "max": 5
    },

    {
      "id": "buildingFloors",
      "label": "Number of floors",
      "type": "number",
      "required": false,
      "sectionId": "sec-building",
      "showIf": { "fieldId": "category", "equals": "Κτίριο" }
    },
    {
      "id": "buildingUse",
      "label": "Building use",
      "type": "select",
      "required": false,
      "allowOther": true,
      "options": ["Residential", "Commercial", "Mixed use"],
      "sectionId": "sec-building",
      "showIf": { "fieldId": "category", "equals": "Κτίριο" }
    },

    {
      "id": "publicSpaceType",
      "label": "Type of public space",
      "type": "select",
      "required": false,
      "options": ["Square", "Park", "Sidewalk", "Playground"],
      "sectionId": "sec-public",
      "showIf": { "fieldId": "category", "equals": "Δημόσιος χώρος" }
    },
    {
      "id": "publicSpaceLit",
      "label": "Adequately lit at night",
      "type": "boolean",
      "required": false,
      "sectionId": "sec-public",
      "showIf": { "fieldId": "category", "equals": "Δημόσιος χώρος" }
    },

    {
      "id": "parkingSpaces",
      "label": "Number of accessible spaces",
      "type": "number",
      "required": false,
      "sectionId": "sec-parking",
      "showIf": { "fieldId": "category", "equals": "Θέση Στάθμευσης ΑμεΑ" }
    },
    {
      "id": "parkingSignage",
      "label": "Signage present",
      "type": "boolean",
      "required": false,
      "sectionId": "sec-parking",
      "showIf": { "fieldId": "category", "equals": "Θέση Στάθμευσης ΑμεΑ" }
    },

    {
      "id": "otherDescription",
      "label": "Describe the category",
      "type": "textarea",
      "required": false,
      "sectionId": "sec-other",
      "showIf": { "fieldId": "category", "equals": "Άλλο" }
    },

    {
      "id": "photos",
      "label": "Site photos",
      "type": "image",
      "required": false,
      "multiple": true
    },
    {
      "id": "notes",
      "label": "Field notes",
      "type": "textarea",
      "required": false,
      "placeholder": "Any additional observations…"
    }
  ]
}
